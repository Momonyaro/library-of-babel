<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AudiobookPlayer.ViewModels"
             xmlns:cc="clr-namespace:AudiobookPlayer.Controls"
             x:Class="AudiobookPlayer.Views.PlayerView"
             x:DataType="vm:MainWindowViewModel">

    <Grid Margin="8" RowDefinitions="*, Auto, Auto, Auto, Auto" RowSpacing="8">
        <!-- Back Button -->
        <Panel Grid.Row="0" VerticalAlignment="Top">
            <Button Content="Back" Padding="6" FontSize="16" HorizontalAlignment="Left"
                    Command="{Binding DataContext.ResetToBrowseCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        </Panel>
        <StackPanel Grid.Row="0" Margin="8" VerticalAlignment="Top" HorizontalAlignment="Right">
            <PathIcon Width="20" Height="20" Foreground="White">
                <PathIcon.Data>
                    <GeometryGroup>
                        <PathGeometry Figures="M6 1H8V15H6L2 11H0V5H2L6 1Z" />
                        <PathGeometry Figures="M14 8C14 5.79086 12.2091 4 10 4V2C13.3137 2 16 4.68629 16 8C16 11.3137 13.3137 14 10 14V12C12.2091 12 14 10.2091 14 8Z" />
                        <PathGeometry Figures="M12 8C12 9.10457 11.1046 10 10 10V6C11.1046 6 12 6.89543 12 8Z" />
                    </GeometryGroup>
                </PathIcon.Data>
            </PathIcon>
            <Slider Orientation="Vertical"
                    Height="100"
                    Minimum="0"
                    Maximum="100"
                    Value="{Binding Volume}">

                <Slider.Resources>
                    <SolidColorBrush x:Key="ThemeAccentBrush" Color="White"/>
                    <SolidColorBrush x:Key="ThemeBorderLowBrush" Color="DarkGray"/>
                </Slider.Resources>
            </Slider>
            <TextBlock Text="{Binding Volume}" TextAlignment="Center" />
        </StackPanel>
        <Panel Grid.Row="0" HorizontalAlignment="Center" Margin="8">
            <Grid RowDefinitions="Auto, Auto, *">
                <TextBlock Grid.Row="0" Text="{Binding CurrentAudiobook.CurrentTitle}" TextAlignment="Center" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="300" FontSize="18" />
                <TextBlock Grid.Row="1" Text="{Binding CurrentAudiobook.CurrentAuthor}" TextAlignment="Center" Foreground="Gray" FontWeight="Bold" TextWrapping="Wrap" FontSize="12" Padding="0 0 0 4" />
                <Border Grid.Row="2" Width="256" Height="256" CornerRadius="8" ClipToBounds="True" Margin="8" HorizontalAlignment="Center"
                    IsVisible="{Binding CurrentAudiobook.CurrentHasCover}">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000"
                                            BlurRadius="4"
                                            OffsetX="8"
                                            OffsetY="8" />
                    </Border.Effect>
                    <Image Source="{Binding CurrentAudiobook.CurrentCover}"
                        Stretch="UniformToFill"  />
                </Border>
            </Grid>
        </Panel>
        <Border Grid.Row="1">
            <Grid>
                <Button x:Name="ChapterButton" CornerRadius="32" Padding="16 8" FontSize="14" BorderBrush="DimGray" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <PathIcon
                        Width="16"
                        Height="16"
                        Data="M0 2H3.58579C4.49129 2 5.35971 2.35971 6 3C6.64029 3.64029 7 4.50871 7 5.41421V11H9V5.41421C9 4.50871 9.35971 3.64029 10 3C10.6403 2.35971 11.5087 2 12.4142 2H16V13H11L9 15H7L5 13H0V2Z"
                        Foreground="DarkGray" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 0"
                        />
                        <TextBlock Text="{Binding CurrentAudiobook.CurrentChapter}" />
                    </StackPanel>
                </Button>
                <Popup x:Name="ChapterPopup"
                    PlacementTarget="{Binding ElementName=ChapterButton}"
                    Placement="Bottom"
                    IsLightDismissEnabled="True"
                    Width="300"
                    MaxHeight="400">

                    <Border Background="#222" Padding="12" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="350">
                            <ItemsControl ItemsSource="{Binding CurrentAudiobook.ChapterList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}" Padding="8" HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.PlayFromChapterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding ID}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <Border Grid.Row="2" CornerRadius="8" Margin="32 0" BorderThickness="1" BorderBrush="White" Padding="2">
            <ProgressBar 
                Minimum="0"
                Maximum="1"
                Value="{Binding CurrentAudiobook.CurrentChapterProgress}" />
        </Border>
        <Panel Grid.Row="3" Margin="32 4 32 16">
            <TextBlock Text="{Binding CurrentAudiobook.CurrentChapterOffset}" Foreground="Gray" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="12" />
            <TextBlock Text="{Binding CurrentAudiobook.CurrentTimeRemaining}" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" />
            <TextBlock Text="{Binding CurrentAudiobook.CurrentChapterEndOffset}" Foreground="Gray" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" />
        </Panel>
        <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Margin="0 0 0 16">
            <Button Content="Ch-" Padding="6" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Command="{Binding DataContext.SkipChapterBackwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Button Content="-15" Padding="6" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Command="{Binding DataContext.SkipBackwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Button Classes="card" CornerRadius="99" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            Command="{Binding DataContext.TogglePlaybackCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <Border CornerRadius="99" Background="#efefef" >
                    <Panel Height="64" Width="64">
                        <PathIcon
                            Width="24"
                            Height="24"
                            Data="M5 16L7 16L15 8L7 -2.7818e-08L5 0L5 16Z"
                            Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4 0 0 0"
                            IsVisible="{Binding !CurrentAudiobook.CurrentIsPlaying}"
                        />
                        <PathIcon
                            Width="24"
                            Height="24"
                            Data="M7 1H2V15H7V1Z M14 1H9V15H14V1Z"
                            Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 0"
                            IsVisible="{Binding CurrentAudiobook.CurrentIsPlaying}" 
                        />
                    </Panel>
                </Border>
            </Button>
            <Button Content="+15" Padding="6" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding DataContext.SkipForwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Button Content="Ch+" Padding="6" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding DataContext.SkipChapterForwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        </StackPanel>
    </Grid>

</UserControl>