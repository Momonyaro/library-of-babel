<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Babel.Converters"
             x:Class="AudiobookPlayer.Controls.PillControl"
             x:Name="pillControl">

    <UserControl.Resources>
        <local:EnumToBooleanConverter x:Key="EnumToBool"/>
        <local:EnumToColorConverter x:Key="EnumToColor"/>
        <local:EnumToForegroundConverter x:Key="EnumToForeground"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Base pill style -->
        <Style Selector="RadioButton.pill">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="8" MinHeight="32">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontSize="16"
                                          FontWeight="Black"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="RadioButton.pill TextBlock">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Border BorderThickness="1" BorderBrush="White" CornerRadius="10" Padding="2" Background="Transparent">
        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="2">
            <!-- Title -->
            <RadioButton Grid.Column="0" Classes="pill" Content="Title"
                         IsChecked="{Binding BrowseTab, Converter={StaticResource EnumToBool}, ConverterParameter=Title, Mode=OneWay}"
                         Command="{Binding SetBrowseTabCommand}" CommandParameter="Title"
                         Background="{Binding BrowseTab, Converter={StaticResource EnumToColor}, ConverterParameter=Title}"
                         Foreground="{Binding BrowseTab, Converter={StaticResource EnumToForeground}, ConverterParameter=Title}" />

            <!-- Author -->
            <RadioButton Grid.Column="1" Classes="pill" Content="Author"
                         IsChecked="{Binding BrowseTab, Converter={StaticResource EnumToBool}, ConverterParameter=Author, Mode=OneWay}"
                         Command="{Binding SetBrowseTabCommand}" CommandParameter="Author"
                         Background="{Binding BrowseTab, Converter={StaticResource EnumToColor}, ConverterParameter=Author}"
                         Foreground="{Binding BrowseTab, Converter={StaticResource EnumToForeground}, ConverterParameter=Author}" />

            <!-- Series -->
            <RadioButton Grid.Column="2" Classes="pill" Content="Series"
                         IsChecked="{Binding BrowseTab, Converter={StaticResource EnumToBool}, ConverterParameter=Series, Mode=OneWay}"
                         Command="{Binding SetBrowseTabCommand}" CommandParameter="Series"
                         Background="{Binding BrowseTab, Converter={StaticResource EnumToColor}, ConverterParameter=Series}"
                         Foreground="{Binding BrowseTab, Converter={StaticResource EnumToForeground}, ConverterParameter=Series}" />
        </Grid>
    </Border>
</UserControl>