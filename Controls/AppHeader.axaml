<UserControl xmlns="https://github.com/avaloniaui"
				xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="50"
				x:Class="AudiobookPlayer.Controls.AppHeader">
	<Panel>
		<Panel VerticalAlignment="Center">
			<StackPanel Orientation="Horizontal">
				<Button HorizontalAlignment="Left" ToolTip.Tip="Refresh Library" Click="OnClick_RefreshLibrary" Padding="6">
					<PathIcon
						Width="20"
						Height="20"
						Data="M10 7L9 6L11.2929 3.70711L10.8013 3.21553C10.023 2.43724 8.96744 2 7.86677 2C4.63903 2 2 4.68015 2 7.93274C2 11.2589 4.69868 14 8 14C9.53708 14 11.0709 13.4144 12.2426 12.2426L13.6569 13.6569C12.095 15.2188 10.0458 16 8 16C3.56933 16 0 12.3385 0 7.93274C0 3.60052 3.50968 0 7.86677 0C9.49787 0 11.0622 0.647954 12.2155 1.80132L12.7071 2.29289L15 0L16 1V7H10Z"
						Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
					/>
				</Button>
				<Button HorizontalAlignment="Left" ToolTip.Tip="Add File" Click="OnClick_AddFile" Padding="6">
					<PathIcon
						Width="20"
						Height="20"
						Data="M9 0H2V16H14V5L9 0ZM7 6V8H5V10H7V12H9V10H11V8H9V6H7Z"
						Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
					/>
				</Button>
				<Button HorizontalAlignment="Left" ToolTip.Tip="Add Folder" Click="OnClick_AddFolder" Padding="6">
					<PathIcon
						Width="20" Height="20"
						Data="M0 1H5L8 3H13V5H3.7457L2.03141 11H4.11144L5.2543 7H16L14 14H0V1Z"
						Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
					/>
				</Button>
			</StackPanel>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="0">
				<TextBox Width="180" HorizontalAlignment="Right" VerticalContentAlignment="Center"
						Watermark="Search..." CornerRadius="8 0 0 8" BorderBrush="White" Background="Transparent" Padding="8 4"
						Text="{Binding DataContext.SearchQuery, 
						RelativeSource={RelativeSource AncestorType=Window}, 
						Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				<Button HorizontalAlignment="Left" ToolTip.Tip="Clear Search" Padding="6" CornerRadius="0 8 8 0"
					Command="{Binding DataContext.ClearSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}">
					<PathIcon
						Width="20"
						Height="20"
						Data="M0 8L6 2H16V14H6L0 8ZM6.79289 6.20711L8.58579 8L6.79289 9.79289L8.20711 11.2071L10 9.41421L11.7929 11.2071L13.2071 9.79289L11.4142 8L13.2071 6.20711L11.7929 4.79289L10 6.58579L8.20711 4.79289L6.79289 6.20711Z"
						Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
					/>
				</Button>
			</StackPanel>
		</Panel>
	</Panel>
</UserControl>
